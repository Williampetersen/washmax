---
import { Icon } from "astro-icon/components";
import Layout from "@/layouts/Layout.astro";

const giftCardUrl = "https://cleanwash.dk/shop/";
const phoneHref = "tel:+4542504551";
const heroVideo = "/videos/frontvideo.mp4";

const trustItems = [
  {
    icon: "bx:bxs-time-five",
    title: "Alle ugens dage",
    text: "Book mobil bilrengoring nar bilen alligevel holder stille.",
  },
  {
    icon: "bx:bxs-map",
    title: "Vi kommer til dig",
    text: "Privatadresse, arbejdsplads eller parkeringsanlaeg pa Sjaelland.",
  },
  {
    icon: "bx:bxs-check-shield",
    title: "Tydelig pris",
    text: "Nummerpladen finder bilkategori og pris for dig.",
  },
];

const priceRules = [
  {
    category: "Varevogn",
    price: 1500,
    description: "Varebil eller totalvaegt over 2.500 kg.",
  },
  {
    category: "Stor bil",
    price: 999,
    description: "Stor familiebil, SUV eller totalvaegt over 2.000 kg.",
  },
  {
    category: "Mellem bil",
    price: 899,
    description: "Almindelig personbil med totalvaegt over 1.300 kg.",
  },
  {
    category: "Lille bil",
    price: 799,
    description: "Kompakt bil under eller lig 1.300 kg.",
  },
];
---

<Layout
  title="Beregn pris online"
  description="Beregn pris online hos CleanWash med dansk nummerpladeopslag, automatisk bilkategori og hurtig booking af mobil bilrengoring.">
  <main id="top" class="px-4 pb-12 sm:px-6">
    <section class="-mx-4 sm:-mx-6">
      <div class="relative overflow-hidden bg-[#071611]">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          class="absolute inset-0 h-full w-full object-cover"
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(3,9,8,0.88)_0%,rgba(5,17,13,0.68)_54%,rgba(7,21,17,0.42)_100%)]"></div>
        <div class="absolute inset-x-0 bottom-0 h-40 bg-[linear-gradient(180deg,transparent,rgba(3,9,8,0.78))]"></div>

        <div class="relative mx-auto grid min-h-[calc(100vh-6rem)] max-w-7xl gap-8 px-4 py-14 sm:px-6 lg:grid-cols-[1fr_0.8fr] lg:items-center lg:px-10">
          <div class="max-w-3xl text-white">
            <p class="text-sm font-semibold uppercase text-[#61c8f4]">
              Mobil bilreng&oslash;ring hos dig
            </p>
            <h1 class="mt-4 max-w-2xl font-display text-[clamp(3rem,7vw,5.9rem)] font-semibold leading-none text-white">
              Beregn pris online
            </h1>
            <p class="mt-5 max-w-xl text-lg leading-8 text-white/78">
              Sl&aring; nummerpladen op, f&aring; bilen fundet automatisk og g&aring;
              direkte videre til booking med den rigtige bilkategori.
            </p>

            <form
              data-plate-form
              class="mt-7 flex max-w-3xl flex-col gap-2 sm:flex-row sm:items-stretch"
            >
              <label class="block sm:w-[20rem]">
                <span class="sr-only">Dansk nummerplade</span>
                <span class="flex h-12 overflow-hidden rounded-md border border-white/30 bg-white shadow-[0_16px_40px_rgba(0,0,0,0.18)] focus-within:border-[#55b9df] focus-within:ring-4 focus-within:ring-[#55b9df]/22">
                  <img
                    src="/DKEU.svg"
                    alt="DK"
                    width="48"
                    height="54"
                    class="h-full w-10 shrink-0 object-cover"
                    loading="eager"
                  />
                  <input
                    data-plate-input
                    name="plate"
                    type="text"
                    inputmode="text"
                    autocomplete="off"
                    autocapitalize="characters"
                    placeholder="AB12345"
                    maxlength="10"
                    class="min-w-0 flex-1 border-0 bg-white px-3 text-xl font-semibold uppercase tracking-[0.08em] text-[#222] outline-none placeholder:text-[#cfcfcf]"
                  />
                </span>
              </label>

              <button
                data-plate-submit
                type="submit"
                class="inline-flex h-12 items-center justify-center gap-2 rounded-md bg-[#55b9df] px-7 text-sm font-semibold text-white shadow-[0_16px_40px_rgba(43,147,220,0.26)] transition hover:bg-[#42a6cb] disabled:cursor-not-allowed disabled:opacity-70"
              >
                <Icon name="bx:search" class="h-5 w-5" />
                <span data-plate-submit-label>Se din pris</span>
              </button>
            </form>

            <div
              data-plate-status
              aria-live="polite"
              class="mt-3 hidden max-w-2xl rounded-md border px-4 py-3 text-sm"
            ></div>

            <p class="mt-3 max-w-2xl text-xs font-semibold text-white/88">
              V&aelig;lg reng&oslash;ring af hele bilen og spar min. 398 kr. inkl.
              gratis voksbehandling.
            </p>

            <div class="mt-6 flex flex-wrap gap-3">
              {
                trustItems.map((item) => (
                  <div class="flex items-center gap-2 rounded-full border border-white/12 bg-white/8 px-4 py-2 text-sm text-white/82 backdrop-blur-sm">
                    <Icon name={item.icon} class="h-5 w-5 text-[#61c8f4]" />
                    <span class="font-semibold">
                      {item.title}
                    </span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="hidden justify-center lg:flex">
            <div class="relative flex h-64 w-64 rotate-[7deg] items-center justify-center rounded-full border-[8px] border-white/85 bg-[radial-gradient(circle_at_40%_30%,#a8ea62,#7bc93b_58%,#62aa24_100%)] p-8 text-center text-white shadow-[0_28px_70px_rgba(0,0,0,0.3)]">
              <div class="absolute inset-[0.65rem] rounded-full border border-white/70"></div>
              <div class="absolute inset-[1.35rem] rounded-full border border-white/25"></div>
              <div class="relative z-10 -rotate-[7deg]">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-white/84">
                  Bestil komplet bilreng&oslash;ring
                </p>
                <p class="mt-4 font-display text-3xl font-semibold leading-tight">
                  F&aring; gratis voksbehandling
                </p>
                <p class="mt-2 text-2xl font-semibold leading-tight">
                  &amp; hel bils rabat
                </p>
                <p class="mt-4 text-xs font-semibold uppercase tracking-[0.16em] text-white/82">
                  Spar minimum
                </p>
                <p class="font-display text-5xl font-semibold leading-none">
                  398,-
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto mt-10 max-w-7xl">
      <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
        <div class="section-shell px-6 py-8 sm:px-8">
          <span class="eyebrow">Prislogik</span>
          <h2 class="mt-5 section-title">
            Den rigtige kategori uden g&aelig;tteri.
          </h2>
          <p class="mt-5 support-copy">
            Nummerpladen bruges til at finde biltype og totalv&aelig;gt. Derfor
            kan CleanWash vise den rigtige pris, f&oslash;r kunden g&aring;r videre
            i bookingflowet.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          {
            priceRules.map((rule) => (
              <article class="rounded-lg border border-[var(--line)] bg-white/86 p-5 shadow-[0_18px_40px_rgba(8,27,21,0.08)]">
                <p class="text-xs font-semibold uppercase text-[var(--muted)]">
                  Bilkategori
                </p>
                <h3 class="mt-3 font-display text-2xl font-semibold text-[var(--ink)]">
                  {rule.category}
                </h3>
                <p class="mt-2 text-3xl font-semibold text-[#2388d1]">
                  {rule.price.toLocaleString("da-DK")} kr
                </p>
                <p class="mt-4 text-sm leading-6 text-[var(--muted)]">
                  {rule.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mx-auto mt-10 max-w-7xl">
      <div class="rounded-lg bg-[#0d1f19] px-6 py-8 text-white shadow-[0_24px_70px_rgba(8,27,21,0.2)] sm:px-8 lg:flex lg:items-center lg:justify-between lg:gap-8">
        <div>
          <p class="text-sm font-semibold uppercase text-[#88ddc2]">
            CleanWash
          </p>
          <h2 class="mt-3 font-display text-3xl font-semibold leading-tight sm:text-4xl">
            Klar til en renere bil uden turen til vaskehallen?
          </h2>
        </div>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row lg:mt-0">
          <a
            href="#top"
            class="inline-flex items-center justify-center gap-2 rounded-md bg-white px-5 py-4 text-sm font-semibold text-[#0d1f19] transition hover:bg-[#eef8f4]"
          >
            <Icon name="bx:search" class="h-5 w-5" />
            Beregn pris
          </a>
          <a
            href={giftCardUrl}
            class="inline-flex items-center justify-center gap-2 rounded-md border border-white/18 px-5 py-4 text-sm font-semibold text-white transition hover:bg-white/8"
          >
            <Icon name="bx:bxs-gift" class="h-5 w-5" />
            Gavekort
          </a>
          <a
            href={phoneHref}
            class="inline-flex items-center justify-center rounded-md border border-white/18 px-5 py-4 text-sm text-white/85 transition hover:bg-white/8"
          >
            42 50 45 51
          </a>
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    const plateForm = document.querySelector("[data-plate-form]");
    const plateInput = document.querySelector("[data-plate-input]");
    const plateSubmit = document.querySelector("[data-plate-submit]");
    const plateSubmitLabel = document.querySelector("[data-plate-submit-label]");
    const plateStatus = document.querySelector("[data-plate-status]");

    const sanitizePlate = (value) =>
      value
        .toUpperCase()
        .replace(/[^A-Z0-9]/g, "")
        .slice(0, 10);

    const setStatus = (message, type = "info") => {
      if (!plateStatus) return;

      plateStatus.textContent = message;
      plateStatus.className = "mt-3 max-w-2xl rounded-md border px-4 py-3 text-sm";

      if (type === "error") {
        plateStatus.classList.add("border-red-200", "bg-red-50", "text-red-700");
        return;
      }

      plateStatus.classList.add("border-[#2388d1]/30", "bg-[#eef8ff]", "text-[#0d526d]");
    };

    const setLoading = (isLoading) => {
      if (!plateSubmit || !plateSubmitLabel) return;
      plateSubmit.disabled = isLoading;
      plateSubmitLabel.textContent = isLoading ? "Tjekker..." : "Se din pris";
    };

    plateInput?.addEventListener("input", () => {
      const sanitized = sanitizePlate(plateInput.value);
      if (plateInput.value !== sanitized) plateInput.value = sanitized;
    });

    plateForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      const plate = sanitizePlate(plateInput?.value || "");
      if (plateInput) plateInput.value = plate;

      if (!/^[A-Z0-9]{2,10}$/.test(plate)) {
        setStatus("Indtast en gyldig dansk nummerplade, fx AB12345.", "error");
        plateInput?.focus();
        return;
      }

      setLoading(true);
      setStatus("Vi tjekker nummerpladen hos MotorAPI.dk...");

      try {
        const response = await fetch(`/api/vehicle/${encodeURIComponent(plate)}`, {
          headers: {
            Accept: "application/json",
          },
        });
        const payload = await response.json().catch(() => ({}));

        if (!response.ok) {
          throw new Error(
            payload?.error ||
              "Nummerpladen kunne ikke findes. Tjek nummeret og prov igen."
          );
        }

        window.location.href = `/booking?plate=${encodeURIComponent(plate)}`;
      } catch (error) {
        setStatus(
          error instanceof Error
            ? error.message
            : "Nummerpladen kunne ikke findes. Tjek nummeret og prov igen.",
          "error"
        );
      } finally {
        setLoading(false);
      }
    });
  </script>
</Layout>

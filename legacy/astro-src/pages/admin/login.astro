---
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";
import {
  getAdminSession,
  isAdminConfigured,
} from "@/lib/server/admin-session";

export const prerender = false;

if (getAdminSession(Astro.cookies)) {
  return Astro.redirect("/admin");
}

const error = Astro.url.searchParams.get("error");
const errorMessage =
  error === "config"
    ? "Admin-login er ikke konfigureret endnu.. Tilføj ADMIN_EMAIL, ADMIN_PASSWORD og ADMIN_SESSION_SECRET."
    : error === "invalid"
      ? "Forkert email eller password."
      : "";
---

<Layout title="Admin login" description="Log ind til CleanWash admin.">
  <main class="px-4 pb-12 pt-10 sm:px-6">
    <section class="mx-auto max-w-5xl">
      <div class="grid gap-6 lg:grid-cols-[0.92fr_1.08fr]">
        <div class="rounded-[2rem] bg-[linear-gradient(155deg,#0d3556,#184e75_45%,#1d6f9a)] p-8 text-white shadow-[0_30px_80px_rgba(8,27,21,0.22)]">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#a7e7ff]">
            CleanWash Admin
          </p>
          <h1 class="mt-4 font-display text-4xl font-semibold leading-tight">
            Booking, kalender og kundeoverblik samlet et sted.
          </h1>
          <p class="mt-5 text-base leading-7 text-white/78">
            Brug adminpanelet til at godkende bookinger, opdatere tider, tilføje
            bookinger manuelt og holde styr pa dagens plan.
          </p>

          <div class="mt-8 grid gap-3">
            <div class="rounded-2xl border border-white/12 bg-white/8 px-4 py-3 text-sm text-white/82">
              Kundeportal med bookinghistorik og profil
            </div>
            <div class="rounded-2xl border border-white/12 bg-white/8 px-4 py-3 text-sm text-white/82">
              Adminhandlinger til godkend, afslut, annuller og slet
            </div>
            <div class="rounded-2xl border border-white/12 bg-white/8 px-4 py-3 text-sm text-white/82">
              Emailbekraeftelser og tidsplan styret fra samme system
            </div>
          </div>
        </div>

        <div class="rounded-[2rem] border border-[var(--line)] bg-white p-8 shadow-[0_24px_70px_rgba(8,27,21,0.12)]">
          <div class="flex items-center gap-3">
            <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#eef8ff] text-[#2388d1]">
              <Icon name="bx:lock-alt" class="h-6 w-6" />
            </span>
            <div>
              <h2 class="font-display text-3xl font-semibold text-[var(--ink)]">
                Log ind
              </h2>
              <p class="mt-1 text-sm text-[var(--muted)]">
                Kun administratorer kan se dette panel.
              </p>
            </div>
          </div>

          {
            errorMessage && (
              <div class="mt-6 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                {errorMessage}
              </div>
            )
          }

          {
            !isAdminConfigured() && (
              <div class="mt-6 rounded-2xl border border-[#cde6f6] bg-[#f6fbff] px-4 py-4 text-sm text-[#1a506d]">
                Mangler opsaetning. Du skal have disse variabler i Vercel:
                `ADMIN_EMAIL`, `ADMIN_PASSWORD`, `ADMIN_SESSION_SECRET`.
              </div>
            )
          }

          <form action="/api/admin/login" method="POST" class="mt-6 grid gap-4">
            <label class="grid gap-2 text-sm text-[var(--ink)]">
              <span class="font-medium">Admin email</span>
              <input
                type="email"
                name="email"
                autocomplete="username"
                class="h-12 rounded-xl border border-[#cbd9e4] bg-white px-4 outline-none transition focus:border-[#55b9df] focus:ring-4 focus:ring-[#55b9df]/12"
              />
            </label>

            <label class="grid gap-2 text-sm text-[var(--ink)]">
              <span class="font-medium">Password</span>
              <input
                type="password"
                name="password"
                autocomplete="current-password"
                class="h-12 rounded-xl border border-[#cbd9e4] bg-white px-4 outline-none transition focus:border-[#55b9df] focus:ring-4 focus:ring-[#55b9df]/12"
              />
            </label>

            <button
              type="submit"
              class="mt-2 inline-flex h-12 items-center justify-center gap-2 rounded-xl bg-[#2388d1] px-5 text-sm font-semibold text-white transition hover:bg-[#1b75b7]">
              <Icon name="bx:log-in" class="h-5 w-5" />
              Gaa til admin
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>

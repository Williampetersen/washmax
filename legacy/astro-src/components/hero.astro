---
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-16 pb-8 md:pt-12 md:pb-24">
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      Professionel bilvask i København og på Sjælland
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      CleanWash tilbyder mobil bilvask, indvendig bilrengøring og bilpleje på
      adressen for private og erhverv.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="/booking"
        class="flex gap-1 items-center justify-center"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name="bx:bxs-cloud-download" />

        Book bilvask
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href="tel:+4542504551"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-black w-4 h-4" name="bx:bxl-github" />
        Ring: 42 50 45 51
      </Link>
    </div>
  </div>
</main>

---
const bookingUrl = "https://cleanwash.dk/book-nu/";
const giftCardUrl = "https://cleanwash.dk/shop/";
---

<footer class="px-4 pb-8 pt-16 sm:px-6">
  <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] border border-[var(--line)] bg-[#081a14] px-6 py-10 text-white shadow-[0_24px_80px_rgba(6,18,15,0.22)] sm:px-10">
    <div class="grid gap-10 lg:grid-cols-[1.3fr_0.8fr_0.8fr]">
      <div class="max-w-xl">
        <img
          src="/logo.png"
          alt="CleanWash"
          class="h-12 w-auto max-w-[14rem] object-contain"
          loading="lazy"
          decoding="async"
        />
        <h2 class="mt-4 font-display text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Mobil bilrengoring med tydelige priser og hurtig booking.
        </h2>
        <p class="mt-4 text-sm leading-7 text-white/68 sm:text-base">
          Vi kommer ud til dig privat, pa jobbet eller der hvor bilen holder.
          Book online pa fa minutter og brug vores nuvaerende bookingflow, mens
          den nye frontend bliver bygget faerdig.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-white/55">
          Hurtige links
        </h3>
        <div class="mt-5 grid gap-3 text-sm text-white/75">
          <a href="/#pakker" class="transition hover:text-white">Pakker</a>
          <a href="/#hvordan" class="transition hover:text-white">Sa nemt er det</a>
          <a href="/#omrader" class="transition hover:text-white">Daekningsomrade</a>
          <a href="/#anmeldelser" class="transition hover:text-white">Anmeldelser</a>
          <a href={giftCardUrl} class="transition hover:text-white">Gavekort</a>
        </div>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-white/55">
          Kontakt
        </h3>
        <div class="mt-5 grid gap-3 text-sm text-white/75">
          <a href="tel:+4542504551" class="transition hover:text-white">
            42 50 45 51
          </a>
          <a href="mailto:info@cleanwash.dk" class="transition hover:text-white">
            info@cleanwash.dk
          </a>
          <p>Alle ugens dage kl. 08-17</p>
          <p>Daekker det meste af Sjaelland</p>
        </div>
        <a
          href={bookingUrl}
          class="mt-6 inline-flex rounded-full bg-[linear-gradient(135deg,#2cd2a6,#15946f)] px-5 py-3 text-sm font-semibold text-[#04150f] transition hover:brightness-105">
          Bestil tid
        </a>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-white/10 pt-6 text-sm text-white/45 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {new Date().getFullYear()} CleanWash. Alle rettigheder forbeholdes.</p>
      <p>Ekstra koersel udenfor daekningsomradet kan udlose et tillaeg pa 250 kr.</p>
    </div>
  </div>
</footer>

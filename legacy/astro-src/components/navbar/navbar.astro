---
const bookingUrl = "https://cleanwash.dk/book-nu/";
const giftCardUrl = "https://cleanwash.dk/shop/";
const phoneDisplay = "42 50 45 51";
const phoneHref = "tel:+4542504551";
const navItems = [
  { label: "Pakker", href: "/#pakker" },
  { label: "Sa nemt er det", href: "/#hvordan" },
  { label: "Daekningsomrade", href: "/#omrader" },
  { label: "Anmeldelser", href: "/#anmeldelser" },
];
---

<header class="sticky top-0 z-50 px-4 pt-4 sm:px-6">
  <div class="mx-auto max-w-7xl">
    <div class="rounded-[1.75rem] border border-black/6 bg-[rgba(255,255,255,0.88)] px-5 py-4 text-[var(--ink)] shadow-[0_18px_60px_rgba(7,19,15,0.12)] backdrop-blur-xl">
      <div class="flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3">
          <img
            src="/logo.png"
            alt="CleanWash"
            class="h-11 w-auto max-w-[13rem] object-contain sm:h-12"
            loading="eager"
            decoding="async"
          />
        </a>

        <nav class="hidden items-center gap-2 lg:flex">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="rounded-full px-4 py-2 text-sm text-[var(--muted)] transition hover:bg-black/4 hover:text-[var(--ink)]">
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="hidden items-center gap-3 lg:flex">
          <a
            href={phoneHref}
            class="rounded-full border border-black/8 px-4 py-2 text-sm text-[var(--muted)] transition hover:border-black/15 hover:text-[var(--ink)]">
            {phoneDisplay}
          </a>
          <a
            href={bookingUrl}
            class="rounded-full bg-[linear-gradient(135deg,#5ec1eb,#39aee0)] px-5 py-2.5 text-sm font-semibold text-white transition hover:brightness-105">
            Se pris og bestil
          </a>
        </div>

        <details class="group relative lg:hidden">
          <summary class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-black/8 px-4 py-2 text-sm text-[var(--ink)] transition hover:border-black/15">
            Menu
            <span class="text-[var(--muted)] transition group-open:rotate-45">+</span>
          </summary>
          <div class="absolute right-0 top-[calc(100%+0.75rem)] w-[min(20rem,calc(100vw-2rem))] rounded-[1.5rem] border border-black/8 bg-white p-4 shadow-[0_20px_60px_rgba(0,0,0,0.16)]">
            <div class="flex flex-col gap-2">
              {
                navItems.map((item) => (
                  <a
                    href={item.href}
                    class="rounded-2xl px-4 py-3 text-sm text-[var(--ink)] transition hover:bg-black/4">
                    {item.label}
                  </a>
                ))
              }
            </div>
            <div class="mt-4 grid gap-3">
              <a
                href={phoneHref}
                class="rounded-2xl border border-black/8 px-4 py-3 text-center text-sm text-[var(--ink)]">
                Ring: {phoneDisplay}
              </a>
              <a
                href={bookingUrl}
                class="rounded-2xl bg-[linear-gradient(135deg,#5ec1eb,#39aee0)] px-4 py-3 text-center text-sm font-semibold text-white">
                Se pris og bestil
              </a>
              <a
                href={giftCardUrl}
                class="rounded-2xl border border-black/8 px-4 py-3 text-center text-sm text-[var(--ink)]">
                Gavekort
              </a>
            </div>
          </div>
        </details>
      </div>
    </div>
  </div>
</header>

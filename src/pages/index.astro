  <script
    is:inline
    define:vars={{
      bookingUrl,
      carCatalog,
      defaultBrand,
      brandLabels,
      brandLogoFiles,
    }}>
    const buttons = Array.from(document.querySelectorAll("[data-package-button]"));
    const panels = Array.from(document.querySelectorAll("[data-package-panel]"));
    const brandCombobox = document.querySelector("[data-brand-combobox]");
    const brandTrigger = document.querySelector("[data-brand-trigger]");
    const brandMenu = document.querySelector("[data-brand-menu]");
    const brandSelect = document.querySelector("[data-brand-select]");
    const brandTriggerLabel = document.querySelector("[data-brand-trigger-label]");
    const brandTriggerLogo = document.querySelector("[data-brand-trigger-logo]");
    const brandOptions = Array.from(document.querySelectorAll("[data-brand-option]"));
    const modelSelect = document.querySelector("[data-model-select]");
    const heroBook = document.querySelector("[data-hero-book]");
    const heroSelection = document.querySelector("[data-hero-selection]");

    const setActivePackage = (id) => {
      buttons.forEach((button) => {
        const isActive = button.dataset.packageButton === id;
        button.classList.toggle("border-transparent", isActive);
        button.classList.toggle("bg-[linear-gradient(135deg,#132f27,#0f7d60)]", isActive);
        button.classList.toggle("text-white", isActive);
        button.classList.toggle(
          "shadow-[0_18px_35px_rgba(16,99,78,0.18)]",
          isActive
        );
        button.classList.toggle("border-[var(--line)]", !isActive);
        button.classList.toggle("bg-white/85", !isActive);
        button.classList.toggle("text-[var(--ink)]", !isActive);
        button.classList.toggle("hover:bg-white", !isActive);
      });

      panels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.dataset.packagePanel !== id);
      });
    };

    const getBrandDisplay = (brand) => brandLabels[brand] || brand;

    const getBrandInitials = (brand) => {
      const words = brand.replace(/-/g, " ").split(" ");

      if (words.length > 1) {
        return words
          .map((word) => word[0] || "")
          .join("")
          .slice(0, 2)
          .toUpperCase();
      }

      return brand.length <= 3 ? brand.toUpperCase() : brand.charAt(0).toUpperCase();
    };

    const updateBrandTrigger = (brand) => {
      if (!brandTriggerLabel || !brandTriggerLogo) return;

      const logo = brandLogoFiles[brand];
      brandTriggerLabel.textContent = getBrandDisplay(brand);
      brandTriggerLogo.innerHTML = "";

      if (logo) {
        const img = document.createElement("img");
        img.src = logo;
        img.alt = `${getBrandDisplay(brand)} logo`;
        img.className = "h-6 w-6 object-contain";
        brandTriggerLogo.appendChild(img);
      } else {
        brandTriggerLogo.textContent = getBrandInitials(brand);
      }

      brandOptions.forEach((option) => {
        const isSelected = option.dataset.brandOption === brand;
        option.classList.toggle("bg-[#f5f8fa]", isSelected);
        option.setAttribute("aria-selected", isSelected ? "true" : "false");
      });
    };

    const closeBrandMenu = () => {
      if (!brandTrigger || !brandMenu) return;
      brandMenu.classList.add("hidden");
      brandTrigger.setAttribute("aria-expanded", "false");
    };

    const toggleBrandMenu = () => {
      if (!brandTrigger || !brandMenu) return;
      const shouldOpen = brandMenu.classList.contains("hidden");
      brandMenu.classList.toggle("hidden", !shouldOpen);
      brandTrigger.setAttribute("aria-expanded", shouldOpen ? "true" : "false");
    };

    const updateModelOptions = (brand) => {
      if (!modelSelect) return;

      const models = carCatalog[brand] || [];
      modelSelect.innerHTML = "";

      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = "Vaelg model";
      placeholder.selected = true;
      modelSelect.appendChild(placeholder);

      models.forEach((model) => {
        const option = document.createElement("option");
        option.value = model;
        option.textContent = model;
        modelSelect.appendChild(option);
      });
    };

    const updateHeroBookingState = () => {
      if (!brandSelect || !modelSelect || !heroBook || !heroSelection) return;

      const brand = brandSelect.value;
      const model = modelSelect.value;
      const brandLabel = getBrandDisplay(brand);

      if (model) {
        const params = new URLSearchParams({
          brand,
          model,
        });
        heroBook.href = `${bookingUrl}?${params.toString()}`;
        heroBook.classList.remove("opacity-60");
        heroSelection.textContent = `${brandLabel} ${model} valgt. Fortsaet til booking.`;
      } else {
        heroBook.href = bookingUrl;
        heroBook.classList.add("opacity-60");
        heroSelection.textContent = `${brandLabel} valgt. Vaelg model for at fortsaette.`;
      }
    };

    if (brandSelect && modelSelect && heroBook) {
      brandSelect.value = defaultBrand;
      updateBrandTrigger(defaultBrand);
      updateModelOptions(defaultBrand);
      updateHeroBookingState();

      modelSelect.addEventListener("change", () => {
        updateHeroBookingState();
      });

      if (brandTrigger && brandMenu) {
        brandTrigger.addEventListener("click", () => {
          toggleBrandMenu();
        });
      }

      brandOptions.forEach((option) => {
        option.addEventListener("click", () => {
          if (!brandSelect) return;
          brandSelect.value = option.dataset.brandOption;
          updateBrandTrigger(brandSelect.value);
          updateModelOptions(brandSelect.value);
          updateHeroBookingState();
          closeBrandMenu();
        });
      });

      heroBook.addEventListener("click", (event) => {
        if (!modelSelect.value) {
          event.preventDefault();
          modelSelect.focus();
        }
      });
    }

    document.addEventListener("click", (event) => {
      if (!brandCombobox || !brandMenu || brandMenu.classList.contains("hidden")) return;
      if (!brandCombobox.contains(event.target)) {
        closeBrandMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeBrandMenu();
      }
    });

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        setActivePackage(button.dataset.packageButton);
      });
    });
  </script>
</Layout>

const brands = Object.keys(carCatalog);
const popularBrands = popularBrandOrder.filter((brand) => brands.includes(brand));
const otherBrands = brands.filter((brand) => !popularBrands.includes(brand));
const defaultModels = carCatalog[defaultBrand];
const getBrandLabel = (brand) => brandLabels[brand] ?? brand;
const getBrandLogo = (brand) => brandLogoFiles[brand] ?? "";
const getBrandInitials = (brand) => {
  const words = brand.replace(/-/g, " ").split(" ");

  if (words.length > 1) {
    return words
      .map((word) => word[0] ?? "")
      .join("")
      .slice(0, 2)
      .toUpperCase();
  }

  return brand.length <= 3 ? brand.toUpperCase() : brand.charAt(0).toUpperCase();
};

